---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getTagCounts } from "@/utils/getTagCounts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { readingList } from "@/data/readingList";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured).slice(0, 3);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const tagStats = getTagCounts(sortedPosts).slice(0, 8);
const latestReading = readingList.slice(0, 4);
const archiveYears = new Set(
  sortedPosts.map(post => post.data.pubDatetime.getFullYear())
).size;
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-8">
      <p class="text-muted-foreground text-sm tracking-[0.24em] uppercase">
        Reinforcement Learning / LLM Post-Training / Reading Notes
      </p>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-6xl">
        为训练与阅读留下可复用的索引
      </h1>
      <a
        target="_blank"
        href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
        class="inline-block"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p class="max-w-3xl text-lg leading-8">
        这里主要记录我在 <strong>RL、LLM 训练</strong> 以及相关论文阅读中的
        结构化笔记。目标不是做资讯流，而是把训练闭环、实现细节和阅读心得沉淀成
        一套能在任意设备快速回看的个人知识索引。
      </p>
      <p class="mt-3 max-w-3xl text-base leading-7">
        内容会以训练笔记、读书笔记和关键术语卡片为主，尽量保持短标题、稳定链接和
        可检索的标签系统。
      </p>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="card-surface px-5 py-4 transition-transform hover:-translate-y-0.5"
        >
          <p class="text-muted-foreground text-sm">文章总数</p>
          <p class="mt-1 text-3xl font-semibold">{sortedPosts.length}</p>
          <p class="mt-2 text-sm leading-6">持续整理训练记录、复现备忘和阅读摘要。</p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "archives")}
          class="card-surface px-5 py-4 transition-transform hover:-translate-y-0.5"
        >
          <p class="text-muted-foreground text-sm">归档年份</p>
          <p class="mt-1 text-3xl font-semibold">{archiveYears}</p>
          <p class="mt-2 text-sm leading-6">按时间线回看每次知识更新与理解迭代。</p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "reading-list")}
          class="card-surface px-5 py-4 transition-transform hover:-translate-y-0.5"
        >
          <p class="text-muted-foreground text-sm">清单条目</p>
          <p class="mt-1 text-3xl font-semibold">{readingList.length}</p>
          <p class="mt-2 text-sm leading-6">把书、论文、技术报告放到同一页统一维护。</p>
        </a>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="border-border border-b pt-12 pb-8">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <section id="topics" class="border-border border-b pt-12 pb-8">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold tracking-wide">专题 / 标签</h2>
          <p class="text-muted-foreground mt-2 leading-7">
            用标签把训练方法、论文主题和工程问题串起来，后续查找会比按时间翻页更快。
          </p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "tags")} class="whitespace-nowrap">
          查看全部
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
      <ul class="mt-6 flex flex-wrap gap-3">
        {tagStats.map(({ tag, tagName, count }) => (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
              class="card-surface inline-flex items-center gap-2 px-4 py-2 text-sm transition-transform hover:-translate-y-0.5"
            >
              <span>{tagName}</span>
              <span class="text-muted-foreground text-xs">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section id="knowledge-index" class="border-border border-b pt-12 pb-8">
      <h2 class="text-2xl font-semibold tracking-wide">知识索引</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <a
          href={getRelativeLocaleUrl(locale, "archives")}
          class="card-surface px-5 py-5 transition-transform hover:-translate-y-0.5"
        >
          <h3 class="text-xl font-semibold">归档</h3>
          <p class="mt-2 leading-7">
            适合回看某个时间段集中读了什么、写了什么，以及主题是怎样演化的。
          </p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "search")}
          class="card-surface px-5 py-5 transition-transform hover:-translate-y-0.5"
        >
          <h3 class="text-xl font-semibold">搜索</h3>
          <p class="mt-2 leading-7">
            当你只记得一个术语、一个算法名字或者一段实验现象时，搜索会最快。
          </p>
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "reading-list")}
          class="card-surface px-5 py-5 transition-transform hover:-translate-y-0.5"
        >
          <h3 class="text-xl font-semibold">阅读清单</h3>
          <p class="mt-2 leading-7">
            把在读、计划读和已读材料放在一起，形成一份可持续维护的长清单。
          </p>
        </a>
      </div>
    </section>

    <section id="reading-list" class="pt-12 pb-6">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold tracking-wide">阅读清单</h2>
          <p class="text-muted-foreground mt-2 leading-7">
            当前这份清单偏向 RL、偏好优化、推理模型和后训练工程。
          </p>
        </div>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "reading-list")}
          class="whitespace-nowrap"
        >
          进入清单
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
      <ul class="mt-6 grid gap-4 md:grid-cols-2">
        {latestReading.map(item => (
          <li class="card-surface px-5 py-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold">{item.title}</h3>
                <p class="text-muted-foreground mt-1 text-sm">
                  {item.author} · {item.kind}
                </p>
              </div>
              <span class="text-accent text-sm whitespace-nowrap">{item.status}</span>
            </div>
            <p class="mt-3 text-sm leading-7">{item.note}</p>
            <p class="text-muted-foreground mt-3 text-xs tracking-wide uppercase">
              {item.topic}
            </p>
          </li>
        ))}
      </ul>
    </section>

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
